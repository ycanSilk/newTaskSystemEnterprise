{
  "rules": {
    "description": "抖音好评评论生成规则，用于在视频评论区@用户，生成真实用户口吻的推荐/分享类评论",
    "fixedNickname": "",
    "commentCount": 5,
    "minWords": 15,
    "maxWords": 30,
    "atPositionDist": {
      "开头": 0.3,
      "中间": 0.4,
      "结尾": 0.3
    },
    "homophoneReplace": {
      "跟": "根",
      "操": "曹",
      "赢": "营"
    },
    "forbiddenPatterns": [
      "大家快看",
      "绝对",
      "一定",
      "保证",
      "肯定中",
      "肯定赢",
      "包中",
      "稳赚"
    ],
    "vocabulary": {
      "开头语": [
        "试了",
        "用了",
        "学了",
        "亲测",
        "看了",
        "根了",
        "跟了"
      ],
      "中间连接": [
        "的方法",
        "说的",
        "推荐的",
        "教的",
        "分享的",
        "这路子",
        "这招"
      ],
      "感受": [
        "有效果",
        "靠谱",
        "不错",
        "没踩坑",
        "见效了",
        "收益好",
        "体验好",
        "真香",
        "惊喜",
        "给力",
        "稳",
        "连营",
        "曹作丝滑"
      ],
      "结尾语气": [
        "感谢分享",
        "学习了",
        "赞",
        "亲测有效",
        "太爽了",
        "可",
        "支持你",
        "加油"
      ]
    },
    "examples": [
      "@桥叔 你推荐的方法试了，有效果靠谱！",
      "亲测@桥叔 教的这招，没踩坑感谢分享",
      "跟了这路子收益好，支持@桥叔",
      "曹作丝滑体验好，感谢分享@桥叔",
      "看了@桥叔 说的见效了，真香！"
    ]
  }
}